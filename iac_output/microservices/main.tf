resource "aws_db_instance" "service_a_db" {
  identifier          = "service-a-db"
  engine              = "postgres"
  instance_class      = "db.t3.micro"
  allocated_storage   = 20
  username            = "app_user"
  password            = var.service_a_db_password
  skip_final_snapshot = true
  publicly_accessible = false
  # Provisioned for service: service-a
}

variable "service_a_db_password" {
  description = "Master password for service-a-db"
  type        = string
  sensitive   = true
}

resource "aws_db_instance" "service_b_db" {
  identifier          = "service-b-db"
  engine              = "mysql"
  instance_class      = "db.t3.micro"
  allocated_storage   = 20
  username            = "app_user"
  password            = var.service_b_db_password
  skip_final_snapshot = true
  publicly_accessible = false
  # Provisioned for service: service-b
}

variable "service_b_db_password" {
  description = "Master password for service-b-db"
  type        = string
  sensitive   = true
}


