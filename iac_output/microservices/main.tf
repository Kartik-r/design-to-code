# Generated by design-to-code Component 2. Pattern: microservices
# Every resource below traces back to something detected in the source
# codebase -- no invented services, ports, or dependencies.

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "aws_region" {
  description = "AWS region to deploy into"
  type        = string
  default     = "us-east-1"
}

variable "vpc_id" {
  description = "VPC to deploy ECS services into"
  type        = string
}

variable "private_subnet_ids" {
  description = "Private subnet IDs for ECS tasks"
  type        = list(string)
}

variable "GATEWAY_ENV" {
  description = "Environment variable required by the application"
  type        = string
}


variable "SERVICE_A_DB_DSN" {
  description = "Sensitive environment variable required by the application"
  type        = string
  sensitive   = true
}

variable "SERVICE_B_DB_DSN" {
  description = "Sensitive environment variable required by the application"
  type        = string
  sensitive   = true
}

resource "aws_ecs_cluster" "main" {
  name = "design-to-code-cluster"
}

resource "aws_security_group" "gateway" {
  name        = "gateway-sg"
  description = "Traffic for service gateway"
  vpc_id      = var.vpc_id
  
  ingress {
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"] # internal only
  }
  
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

resource "aws_ecs_task_definition" "gateway" {
  family                   = "gateway"
  requires_compatibilities = ["FARGATE"]
  network_mode             = "awsvpc"
  cpu                      = "256"
  memory                   = "512"

  container_definitions = jsonencode([
    {
      name  = "gateway"
      image = "REPLACE_WITH_ECR_IMAGE_URI_FOR_gateway"
      portMappings = [
        { containerPort = 8080, protocol = "tcp" }
      ]
      environment = [
        { name = "GATEWAY_ENV", value = var.GATEWAY_ENV },
        
      ]
      secrets = [
        
      ]
    }
  ])
}

resource "aws_ecs_service" "gateway" {
  name            = "gateway"
  cluster         = aws_ecs_cluster.main.id
  task_definition = aws_ecs_task_definition.gateway.arn
  desired_count   = 1
  launch_type     = "FARGATE"

  network_configuration {
    subnets         = var.private_subnet_ids
    security_groups = [aws_security_group.gateway.id]
  }
  
}

resource "aws_security_group" "service_a" {
  name        = "service-a-sg"
  description = "Traffic for service service-a"
  vpc_id      = var.vpc_id
  
  ingress {
    from_port   = 9001
    to_port     = 9001
    protocol    = "tcp"
    cidr_blocks = ["10.0.0.0/8"] # internal only
  }
  
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

